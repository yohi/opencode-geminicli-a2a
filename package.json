{
  "name": "opencode-geminicli-a2a-provider",
  "version": "0.1.2",
  "type": "module",
  "description": "OpenCode custom provider plugin that communicates with Gemini CLI via A2A protocol",
  "opencode": {
    "type": "provider",
    "displayName": "Gemini CLI (A2A)",
    "description": "Gemini CLI A2A プロトコル経由のプロバイダー",
    "models": [
      {
        "id": "gemini-3-pro-preview",
        "name": "Gemini 3 Pro Preview (A2A)"
      },
      {
        "id": "gemini-3.1-pro-preview",
        "name": "Gemini 3.1 Pro Preview (A2A)"
      },
      {
        "id": "gemini-3.1-pro-preview-customtools",
        "name": "Gemini 3.1 Pro Preview Custom Tools (A2A)"
      },
      {
        "id": "gemini-3-flash-preview",
        "name": "Gemini 3 Flash Preview (A2A)"
      },
      {
        "id": "gemini-2.5-pro",
        "name": "Gemini 2.5 Pro (A2A)"
      },
      {
        "id": "gemini-2.5-flash",
        "name": "Gemini 2.5 Flash (A2A)"
      },
      {
        "id": "gemini-2.5-flash-lite",
        "name": "Gemini 2.5 Flash Lite (A2A)"
      }
    ]
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "update-models": "tsx scripts/update-models.ts"
  },
  "dependencies": {
    "@ai-sdk/provider": "^1.0.0",
    "@ai-sdk/provider-utils": "^2.0.0",
    "ofetch": "^1.4.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "files": [
    "dist"
  ],
  "license": "MIT"
}