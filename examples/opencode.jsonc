// ~/.config/opencode/opencode.jsonc の設定例
{
    // ---------------------------------------------------------
    // プラグイン設定
    // ---------------------------------------------------------
    // npm link 等で追加したカスタムプロバイダーを読み込むための設定
    "plugins": [
        "opencode-geminicli-a2a-provider"
    ],
    // ---------------------------------------------------------
    // プロバイダーとモデルの設定
    // ---------------------------------------------------------
    // デフォルトで使用するプロバイダー名
    // このプラグインが提供するプロバイダーIDは 'opencode-geminicli-a2a' です。
    "provider": "opencode-geminicli-a2a",
    // デフォルトで使用するモデル名
    // package.json でエクスポートされているモデルIDを指定します。
    // 対応モデル: gemini-2.5-pro, gemini-2.5-flash, gemini-1.5-pro
    "model": "gemini-2.5-pro",
    // 個別のプロバイダーに対する詳細設定
    "providers": {
        "opencode-geminicli-a2a": {
            "model": "gemini-2.5-flash"
        }
    },
    // ---------------------------------------------------------
    // Gemini CLI (A2A) 固有の設定
    // ---------------------------------------------------------
    // プロバイダー内部で利用されるサーバーへの接続情報
    // ※この設定は環境変数 (GEMINI_A2A_PORT等) よりも優先されます。
    "a2aProvider": {
        // A2A サーバーのホスト名 (デフォルト: 127.0.0.1)
        "host": "127.0.0.1",
        // A2A サーバーの待ち受けポート (デフォルト: 41242)
        "port": 41242,
        // 接続に使用するプロトコル (http または https, デフォルト: http)
        "protocol": "http",
        // 認証が必要な場合の Bearer トークン (任意)
        "token": "your-secret-token"
    },
    // ---------------------------------------------------------
    // その他の OpenCode 設定
    // ---------------------------------------------------------
    // OpenCode の動作に関するグローバルなオプション（例）
    // UI の言語設定
    "language": "ja",
    // デバッグや詳細な出力を有効化する場合
    "verbose": true
}